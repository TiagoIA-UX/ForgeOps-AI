# ======================================================
# ZAEA — Variáveis de Ambiente
# ======================================================
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local no git

# ----------------------------
# Supabase
# ----------------------------
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# ----------------------------
# Groq AI (llama-3.3-70b) — gratuito em groq.com
# ----------------------------
GROQ_API_KEY=gsk_...

# ----------------------------
# Telegram Bot — gratuito via @BotFather
# ----------------------------
TELEGRAM_BOT_TOKEN=seu-bot-token
TELEGRAM_CHAT_ID=seu-chat-id

# ----------------------------
# Autenticação interna da API
# Gere com: openssl rand -hex 32
# ----------------------------
INTERNAL_API_SECRET=gere-um-segredo-forte-aqui

# ----------------------------
# GitHub (para o Surgeon criar PRs)
# ----------------------------
GITHUB_TOKEN=ghp_...
GITHUB_REPO_OWNER=TiagoIA-UX
GITHUB_REPO_NAME=ZAEA

# ----------------------------
# App
# ----------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ----------------------------
# AI Gateway (Groq / Vercel AI Gateway)
# Gere em: https://vercel.com/docs/ai-gateway
# ----------------------------
AI_GATEWAY_API_KEY=sua-ai-gateway-key-aqui