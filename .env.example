# ForgeOps AI — Environment Variables
# Copie para .env.local e preencha com seus valores

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI (Groq + Vercel AI Gateway) ─────────────────────────
GROQ_API_KEY=gsk_...
VERCEL_AI_GATEWAY_TOKEN=vck_...   # opcional: cache + logging

# ── Telegram (alertas) ────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-...
TELEGRAM_CHAT_ID=-100123456789

# ── Segurança interna ─────────────────────────────────────
INTERNAL_API_SECRET=your-random-secret-min-32chars
ADMIN_SECRET_KEY=your-admin-secret

# ── URL pública (para o Surgeon gravar knowledge) ─────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
